{
    "agent_parameters" :
    {
        "num_agents" : 100,
        "new_machines_after_mutation": 25,

        "machine_parameters" :
        {
            "behavior" : "selfish",
            "observed_span" : 300,
            "observation_type" : "trip_info_eta",
            "group_vicinity": false
        },

        "human_parameters" :
        {
            "model" : "gawron",
            "alpha": 0.2,
            "beta" : 1.5,
            "beta_randomness" : 0.1,
            "deterministic" : false,
            "remember" : 5
        },

        "simulation_timesteps" : "${simulator_parameters.simulation_timesteps}",
        "origins" : "${path_generation_parameters.origins}",
        "destinations" : "${path_generation_parameters.destinations}",
        "action_space_size" : "${path_generation_parameters.number_of_paths}",
        "records_folder" : "${plotter_parameters.records_folder}"
    },

    "environment_parameters":
    {
        "number_of_days" : 1,
        "save_every" : 1,

        "action_space_size" : "${path_generation_parameters.number_of_paths}"
    },

    "simulator_parameters":
    {
        "network_name" : "csomor",
        "custom_network_folder" : "NA",
        "simulation_timesteps" : 3600,
        "sumo_type" : "sumo",
        "stuck_time" : 600,
        "daily_reseed" : false,
        "use_libsumo": false,


        "number_of_paths" : "${path_generation_parameters.number_of_paths}",
        "plots_folder": "${plotter_parameters.plots_folder}",
        "records_folder" : "${plotter_parameters.records_folder}"
    },
        
    "path_generation_parameters":
    {
        "number_of_paths" : 3,
        "beta" : -3,
        "weight" : "time",
        "num_samples" : 100,
        "path_gen_workers" : 4,
        "visualize_paths" : true,

        "origins" : "default",
        "destinations" : "default",

        "records_folder" : "${plotter_parameters.records_folder}"
    }, 

    "plotter_parameters":
    {
        "records_folder": "training_records",
        "plots_folder": "plots",

        "plot_choices" : "all",
        "smooth_by" : 50,
        "phases" : [0, 100],
        "phase_names" : [
            "Human learning", 
            "Mutation - Machine learning"
        ]
    }
}
